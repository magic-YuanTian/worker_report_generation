# Copy this file to backend/.env (or export these variables in your shell)
# before running the backend.

# Azure OpenAI endpoint, e.g. https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI key (do NOT commit a real key)
AZURE_OPENAI_API_KEY=

# Chat/completion deployment
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_LLM_MODEL=gpt-4o

# Embedding deployment
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
